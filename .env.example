# === Joplin Server (Sync Backend) ===
JOPLIN_SERVER_URL=http://joplin-server:22300
JOPLIN_SERVER_USER=email@example.com
JOPLIN_SERVER_PASSWORD=your_secure_password

# === Joplin Data API Token ===
# Used by both joplin-cli (to secure the API) and joplin-mcp (to authenticate)
# Generate with: openssl rand -hex 32
JOPLIN_TOKEN=your_api_token_here

# === E2EE Encryption Password ===
# If your Joplin data uses End-to-End Encryption, set the master password here.
# Without this, encrypted notebooks and notes will not be visible.
JOPLIN_ENCRYPTION_PASSWORD=

# === Sync Interval (seconds) ===
SYNC_INTERVAL=300

# === MCP Server ===
# Port exposed on the Docker host for the MCP server
MCP_PORT=8000

# === Optional: Notebook Filter ===
# Comma-separated list of notebook names to restrict access to.
# Leave empty for unrestricted access to all notebooks.
JOPLIN_NOTEBOOK_FILTER=

# === Authentik OAuth 2.1 (for Claude.ai remote MCP) ===
# Base URL of your Authentik instance
AUTHENTIK_URL=https://authentik.example.com
# Application slug in Authentik (default: joplin-mcp)
AUTHENTIK_SLUG=joplin-mcp
# OAuth2 Client ID and Secret from the Authentik Provider
AUTHENTIK_CLIENT_ID=your_client_id_here
AUTHENTIK_CLIENT_SECRET=your_client_secret_here
