# Joplin Server connection for integration tests
# Copy to .env and fill in your values:
#   cp .env.example .env

JOPLIN_SERVER_URL=http://joplin.example.com:22300
JOPLIN_SERVER_USER=you@example.com
JOPLIN_SERVER_PASSWORD=your_password

# End-to-end encryption password (leave empty if not using E2EE)
JOPLIN_ENCRYPTION_PASSWORD=

# Optional overrides
# JOPLIN_PORT=41184
# JOPLIN_TOKEN=your_token_here
